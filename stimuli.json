{
  "metadata": {
    "description": "Ghost Touch haptic evaluation — redesigned",
    "part1_description": "Haptic Annotation: user designs ideal profile for each description",
    "part2_description": "Pipeline Evaluation: rate 3 profiles (pipeline/rule-based/random) on 1-7 Likert",
    "n_part1_trials": 10,
    "n_part2_trials": 10,
    "parameters": {
      "amplitude_pct": {
        "min": 0,
        "max": 100,
        "default": 50,
        "unit": "%"
      },
      "frequency_hz": {
        "min": 20,
        "max": 300,
        "default": 150,
        "unit": "Hz"
      },
      "thermal_delta_c": {
        "min": -5,
        "max": 5,
        "default": 0,
        "step": 0.5,
        "unit": "°C"
      },
      "roughness": {
        "min": 0,
        "max": 100,
        "default": 30,
        "unit": ""
      },
      "onset_ms": {
        "min": 50,
        "max": 2000,
        "default": 500,
        "unit": "ms"
      },
      "duration_ms": {
        "min": 200,
        "max": 6000,
        "default": 2000,
        "unit": "ms"
      }
    }
  },
  "families": [
    {
      "id": "cold_ice",
      "name": "COLD/ICE",
      "category": "Environmental Transformation",
      "excerpt": "The room went ice cold, like walking into a freezer. The kind of chill that sinks into your bones and doesn't leave even after you step away."
    },
    {
      "id": "absence_void",
      "name": "ABSENCE/VOID",
      "category": "Liminal Materiality",
      "excerpt": "It felt like nothing was there but something was missing—like a hole in the air where a person should be. An empty shape pressing against you."
    },
    {
      "id": "electricity_static",
      "name": "ELECTRICITY/STATIC",
      "category": "Forceful Encounter",
      "excerpt": "A cluster of energy hovering just above the skin, like sparks jumping between fingertips. The hair on my arms stood straight up."
    },
    {
      "id": "mist_air_smoke",
      "name": "MIST/AIR/SMOKE",
      "category": "Environmental Transformation",
      "excerpt": "A gentle breeze passed through the room though all windows were closed, like walking through fog. It moved around me slowly, then was gone."
    },
    {
      "id": "pressure_force",
      "name": "PRESSURE/FORCE",
      "category": "Forceful Encounter",
      "excerpt": "Sudden pressure on my chest, like an invisible hand pressing down hard. It held me there for a few seconds before lifting."
    },
    {
      "id": "water_liquid",
      "name": "WATER/LIQUID",
      "category": "Environmental Transformation",
      "excerpt": "It felt like something warm and liquid was flowing down my arm, though nothing was there. A smooth, slow trickle from shoulder to fingertips."
    },
    {
      "id": "temperature_change",
      "name": "TEMPERATURE_CHANGE",
      "category": "Environmental Transformation",
      "excerpt": "The air shifted from normal to burning hot in seconds, then back to cold. Like waves of heat and chill rolling through the space."
    },
    {
      "id": "tingling_prickling",
      "name": "TINGLING/PRICKLING",
      "category": "Liminal Materiality",
      "excerpt": "Tiny pinpricks crawling up my spine, like static electricity dancing on my skin. Not painful, but impossible to ignore."
    },
    {
      "id": "vibration_pulse",
      "name": "VIBRATION/PULSE",
      "category": "Forceful Encounter",
      "excerpt": "A deep, rhythmic pulsing that I felt in my chest, like a heartbeat that wasn't mine. It came in steady waves, then stopped."
    },
    {
      "id": "fabric_veil_cobweb",
      "name": "FABRIC/VEIL/COBWEB",
      "category": "Liminal Materiality",
      "excerpt": "Something gossamer-thin brushed across my face, like walking through an invisible cobweb. So light I almost didn't notice it."
    }
  ],
