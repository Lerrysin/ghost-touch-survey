  "part1_trials": [
    {
      "trial_id": "ann_01",
      "target_family": "cold_ice",
      "target_family_name": "COLD/ICE",
      "excerpt": "The room went ice cold, like walking into a freezer. The kind of chill that sinks into your bones and doesn't leave even after you step away.",
      "excerpt_zh": "整个房间一下子冷得像冰窖，仿佛迎面走进了冷冻库。那种寒意直往骨头里钻，冷得手指都发麻。"
    },
    {
      "trial_id": "ann_02",
      "target_family": "tingling_prickling",
      "target_family_name": "TINGLING/PRICKLING",
      "excerpt": "Tiny pinpricks crawling up my spine, like static electricity dancing on my skin. Not painful, but impossible to ignore.",
      "excerpt_zh": "细小如针刺般的麻点沿着我的脊背一路往上爬，像静电在皮肤上跳舞。不算疼，却让人根本无法忽视——那股挥之不去的酥麻持续不停。"
    },
    {
      "trial_id": "ann_03",
      "target_family": "fabric_veil_cobweb",
      "target_family_name": "FABRIC/VEIL/COBWEB",
      "excerpt": "Something gossamer-thin brushed across my face, like walking through an invisible cobweb. So light I almost didn't notice it.",
      "excerpt_zh": "有什么薄如蝉翼的东西轻轻掠过我的脸，像一头撞进了看不见的蛛网。轻得让我几乎怀疑自己是否真的感觉到了，但那丝发痒的痕迹却迟迟不散。"
    },
    {
      "trial_id": "ann_04",
      "target_family": "water_liquid",
      "target_family_name": "WATER/LIQUID",
      "excerpt": "It felt like something warm and liquid was flowing down my arm, though nothing was there. A smooth, slow trickle from shoulder to fingertips.",
      "excerpt_zh": "感觉像有什么温热的液体正顺着我的手臂往下流，然而那里其实什么也没有。那股流动平滑而稳定，像温水从肩头缓缓浇下，一路淌到手腕。"
    },
    {
      "trial_id": "ann_05",
      "target_family": "pressure_force",
      "target_family_name": "PRESSURE/FORCE",
      "excerpt": "Sudden pressure on my chest, like an invisible hand pressing down hard. It held me there for a few seconds before lifting.",
      "excerpt_zh": "胸口猛然压下一股力量，像一只看不见的手狠狠按住我。它将我死死钉在那里几秒钟，沉重得无法挣脱，随后又在一瞬间全部松开。"
    },
    {
      "trial_id": "ann_06",
      "target_family": "vibration_pulse",
      "target_family_name": "VIBRATION/PULSE",
      "excerpt": "A deep, rhythmic pulsing that I felt in my chest, like a heartbeat that wasn't mine. It came in steady waves, then stopped.",
      "excerpt_zh": "我胸口深处传来一种低沉而有节律的搏动，像一颗不属于我的心脏在跳。它一波一波稳定袭来，每一下都在我全身回荡震颤。"
    },
    {
      "trial_id": "ann_07",
      "target_family": "mist_air_smoke",
      "target_family_name": "MIST/AIR/SMOKE",
      "excerpt": "A gentle breeze passed through the room though all windows were closed, like walking through fog. It moved around me slowly, then was gone.",
      "excerpt_zh": "明明所有窗户都关着，房间里却掠过一阵轻柔的风，像穿行在雾里。它在皮肤上留下微凉而潮湿的触感，几秒后便悄然消散。"
    },
    {
      "trial_id": "ann_08",
      "target_family": "absence_void",
      "target_family_name": "ABSENCE/VOID",
      "excerpt": "It felt like nothing was there but something was missing—like a hole in the air where a person should be. An empty shape pressing against you.",
      "excerpt_zh": "感觉那里明明什么都没有，却又像缺失了什么——仿佛空气中有一个本该站着人的空洞。那是一种空茫而中空的异样感，好像那片空间本身有重量，却没有实体。"
    },
    {
      "trial_id": "ann_09",
      "target_family": "temperature_change",
      "target_family_name": "TEMPERATURE_CHANGE",
      "excerpt": "The air shifted from normal to burning hot in seconds, then back to cold. Like waves of heat and chill rolling through the space.",
      "excerpt_zh": "空气在短短几秒内从平常骤然变得灼热滚烫，接着又迅速转冷。像一阵阵热浪与寒意轮番冲刷全身，每一次转换都尖锐而分明。"
    },
    {
      "trial_id": "ann_10",
      "target_family": "electricity_static",
      "target_family_name": "ELECTRICITY/STATIC",
      "excerpt": "A cluster of energy hovering just above the skin, like sparks jumping between fingertips. The hair on my arms stood straight up.",
      "excerpt_zh": "一团能量悬停在皮肤上方，仿佛火花在指尖之间跳跃。手臂上的汗毛一下子都竖了起来，还有一种强烈的嗡鸣感，几乎像电流掠过般酥麻震颤。"
    }
  ],
